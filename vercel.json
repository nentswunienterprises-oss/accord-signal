{
  "rewrites": [
    {
      "source": "/services",
      "destination": "/services/index.html"
    },
    {
      "source": "/os",
      "destination": "/os/index.html"
    },
    {
      "source": "/brief",
      "destination": "/brief/index.html"
    },
    {
      "source": "/admin",
      "destination": "/admin/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    }
  ]
}
